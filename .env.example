# Copy to .env and adjust.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fbca
DB_PASSWORD=fbca
DB_DATABASE=fbca

# DEV ONLY: auto-create tables from entities. Use migrations in production.
DB_SYNCHRONIZE=true

# JWT (validated by JwtConfig at startup). EXP must match <number><ms|s|m|h|d>.
JWT_ACCESS_KEY=dev-access-secret-change-me
JWT_ACCESS_EXP=15m
JWT_REFRESH_KEY=dev-refresh-secret-change-me
JWT_REFRESH_EXP=7d

PORT=3000
